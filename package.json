{
  "name": "astromeda-ec",
  "private": true,
  "sideEffects": false,
  "version": "2026.1.1",
  "type": "module",
  "scripts": {
    "build": "shopify hydrogen build && node -e \"const fs=require('fs');const d='./dist/server';fs.readdirSync(d).filter(f=>f.endsWith('.map')).forEach(f=>fs.unlinkSync(d+'/'+f))\"",
    "dev": "shopify hydrogen dev --codegen",
    "preview": "shopify hydrogen preview --build",
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "lint:agents": "eslint agents/ --ext .ts --ignore-pattern '**/__tests__/**' --ignore-pattern '**/*.test.ts'",
    "typecheck": "react-router typegen && tsc --noEmit",
    "postinstall": "node --experimental-vm-modules scripts/patch-shopify-cli.js && node --experimental-vm-modules scripts/patch-hydrogen-vendor.js",
    "codegen": "shopify hydrogen codegen && react-router typegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "prettier": "@shopify/prettier-config",
  "dependencies": {
    "@shopify/hydrogen": "2026.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "isbot": "^5.1.22",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "7.12.0",
    "react-router-dom": "7.12.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.1.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@graphql-codegen/cli": "5.0.2",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "7.12.0",
    "@react-router/fs-routes": "7.12.0",
    "@shopify/cli": "3.85.4",
    "@shopify/hydrogen-codegen": "0.3.3",
    "@shopify/mini-oxygen": "4.0.1",
    "@shopify/oxygen-workers-types": "^4.1.6",
    "@shopify/prettier-config": "^1.1.2",
    "@tailwindcss/vite": "^4.1.6",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/eslint": "^9.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "graphql-config": "^5.0.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.2",
    "vite": "^6.2.4",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "browserslist": [
    "defaults"
  ]
}
