# Astromeda EC — 環境変数テンプレート
# cp .env.example .env

# ═══════════════════════════════════════════════════════════════════════════
# === Shopify 統合（必須）===
# ═══════════════════════════════════════════════════════════════════════════
# Public APIs（フロントエンド・Storefront API）
PUBLIC_STOREFRONT_ID=
PUBLIC_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=staging-mining-base.myshopify.com
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=

# Private APIs（バックエンド・Admin API）
PRIVATE_STOREFRONT_API_TOKEN=
SHOP_ID=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_SHOP_DOMAIN=

# Session管理
SESSION_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# === 管理者認証（推奨）===
# ═══════════════════════════════════════════════════════════════════════════
# ADMIN_PASSWORD: Set a strong password (12+ chars: uppercase, lowercase, numbers, symbols)
ADMIN_PASSWORD=
HEALTH_CHECK_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# === Webhook & Webhook Signature（推奨）===
# ═══════════════════════════════════════════════════════════════════════════
SHOPIFY_WEBHOOK_SECRET=
WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# === Analytics & Tracking（オプション）===
# ═══════════════════════════════════════════════════════════════════════════
# Google Analytics 4
PUBLIC_GA_MEASUREMENT_ID=
GA4_API_SECRET=

# Microsoft Clarity
PUBLIC_CLARITY_PROJECT_ID=

# Google Tag Manager
PUBLIC_GTM_CONTAINER_ID=

# Meta Pixel (Facebook)
PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# === Database（Phase 1 Brainstem）===
# ═══════════════════════════════════════════════════════════════════════════
# D1 Database（Cloudflare Workers）
# セットアップ: wrangler d1 create astromeda-ec-db
DATABASE_URL=

# ═══════════════════════════════════════════════════════════════════════════
# === AI Brain（Phase 2 — 高次認知判断エンジン）===
# ═══════════════════════════════════════════════════════════════════════════
# Anthropic Claude API
ANTHROPIC_API_KEY=

# OpenAI GPT-4o/GPT-4o-mini
OPENAI_API_KEY=

# Google Gemini Flash/Pro
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# === Security（免疫系 — 管理者認証・認可）===
# ═══════════════════════════════════════════════════════════════════════════
# 2要素認証（Phase 2）
# 有効化: ADMIN_2FA_ENABLED=true
ADMIN_2FA_ENABLED=false

# IP許可リスト（ホワイトリスト）
# フォーマット: 192.168.1.1,10.0.0.0/8,::1
# 未設定=全IP許可（開発モード）
ADMIN_ALLOWED_IPS=

# ═══════════════════════════════════════════════════════════════════════════
# === Notifications（感覚神経系 — 管理者への通知配信）===
# ═══════════════════════════════════════════════════════════════════════════
# Slack Incoming Webhook（https://hooks.slack.com/services/...）
SLACK_WEBHOOK_URL=

# 管理者メールアドレス
ADMIN_EMAIL=

# Resend Email API（メール送信サービス）
# https://resend.com/api-keys
RESEND_API_KEY=

# 通知用Webhook URL（外部インテグレーション）
NOTIFICATION_WEBHOOK_URL=
