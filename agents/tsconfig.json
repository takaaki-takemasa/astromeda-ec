{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@core/*": ["./core/*"],
      "@registry/*": ["./registry/*"],
      "@l0/*": ["./l0/*"],
      "@l1/*": ["./l1/*"],
      "@l2/*": ["./l2/*"],
      "@pipelines/*": ["./pipelines/*"],
      "@config/*": ["./config/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
